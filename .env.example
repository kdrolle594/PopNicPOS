# ── Railway dashboard (backend environment variables) ──────────────────────────

# Aiven MySQL connection string (required)
MYSQL_URI=mysql://avnadmin:PASSWORD@mysql-xxxx.aivencloud.com:PORT/defaultdb

# Port — Railway sets this automatically; use 3000 for local dev
PORT=3000

# GitHub Pages frontend URL — used to restrict CORS in production
# Example: https://kdrol.github.io/popnic-pos
FRONTEND_URL=

# ── GitHub Actions secrets (set in repo Settings → Secrets and variables → Actions) ──

# Railway backend URL — no trailing slash
# Example: https://popnic-pos-production.up.railway.app
VITE_API_URL=

# GitHub Pages base path — set to /YOUR-REPO-NAME/ (include trailing slash)
# Example: /popnic-pos/
# Leave empty or set to / if using a custom domain
VITE_BASE_PATH=
